@{
    Layout = null;
    var message = ViewData["Message"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - NimBus</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #1E1E1E; color: #E2E8F0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: #282C34; border-radius: 12px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
        h1 { font-size: 1.5rem; text-align: center; margin-bottom: 8px; }
        .subtitle { text-align: center; color: #94A3B8; font-size: 0.9rem; margin-bottom: 28px; }
        label { display: block; font-size: 0.85rem; color: #94A3B8; margin-bottom: 4px; }
        input[type="email"] { width: 100%; padding: 10px 12px; border: 1px solid #3E4451; border-radius: 6px; background: #1E1E1E; color: #E2E8F0; font-size: 0.95rem; margin-bottom: 16px; outline: none; }
        input:focus { border-color: #0078D4; }
        .btn-primary { display: block; width: 100%; padding: 12px; border: none; border-radius: 6px; font-size: 0.95rem; font-weight: 600; cursor: pointer; background: #0078D4; color: white; }
        .btn-primary:hover { background: #2B9AFF; }
        .links { text-align: center; margin-top: 16px; font-size: 0.85rem; }
        .links a { color: #0078D4; text-decoration: none; }
        .links a:hover { text-decoration: underline; }
        .success { background: #14532D; color: #86EFAC; padding: 10px 14px; border-radius: 6px; font-size: 0.85rem; margin-bottom: 16px; }
    </style>
</head>
<body>
    <div class="card">
        <h1>NimBus</h1>
        <p class="subtitle">Reset your password</p>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="success">@message</div>
        }
        else
        {
            <form method="post" action="/account/forgot-password">
                @Html.AntiForgeryToken()
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autofocus />
                <button type="submit" class="btn-primary">Send reset link</button>
            </form>
        }

        <div class="links">
            <a href="/account/login">Back to sign in</a>
        </div>
    </div>
</body>
</html>
