# Defaults match the ports the AppHost pins (see CrmErpDemo.AppHost/Program.cs).
# Override only if you've changed those pins or are running against a different host.

# CRM REST API (used to create/read/delete CRM-side entities)
CRM_API_URL=http://localhost:5080

# ERP REST API (used to create/read/delete ERP-side entities AND toggle failure modes)
ERP_API_URL=http://localhost:5090

# NimBus management WebApp (used to view endpoint status and resubmit failed messages)
NIMBUS_OPS_URL=http://localhost:28376

# Optional: how long to wait for cross-system propagation (ms)
PROPAGATION_TIMEOUT_MS=60000

# Optional: how long to wait for messages to land in NimBus admin as Failed (ms)
FAILED_MESSAGE_TIMEOUT_MS=45000
