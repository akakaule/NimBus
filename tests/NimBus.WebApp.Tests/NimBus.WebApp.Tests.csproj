<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Suppress the npm/SPA targets that the WebApp project would otherwise
         drag in if we referenced it directly. We don't reference WebApp; we
         pull in only the two source files needed (the hub + constants). -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0-preview.1.25120.3" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" Version="10.0.0-preview.1.25120.3" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" Version="10.0.0-preview.1.25120.3" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.1" />
    <PackageReference Include="MSTest.TestAdapter" Version="2.2.10" />
    <PackageReference Include="MSTest.TestFramework" Version="2.2.10" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\NimBus.Extensions.Identity\NimBus.Extensions.Identity.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pull the real GridEventsHub class and Constants source files in by
         compile reference, so the tests exercise the actual production types
         without bringing in NimBus.WebApp's npm/SPA build chain. -->
    <Compile Include="..\..\src\NimBus.WebApp\Hubs\GridEventsHub.cs" Link="WebAppSources\GridEventsHub.cs" />
    <Compile Include="..\..\src\NimBus.WebApp\Constants.cs" Link="WebAppSources\Constants.cs" />
  </ItemGroup>

</Project>
