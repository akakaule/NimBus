@{
    Layout = null;
    var message = ViewData["Message"] as string ?? "Check your email for a confirmation link.";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Confirmation - NimBus</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #1E1E1E; color: #E2E8F0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .card { background: #282C34; border-radius: 12px; padding: 40px; width: 100%; max-width: 400px; box-shadow: 0 4px 24px rgba(0,0,0,0.3); text-align: center; }
        h1 { font-size: 1.5rem; margin-bottom: 16px; }
        .message { color: #94A3B8; font-size: 0.95rem; line-height: 1.6; margin-bottom: 24px; }
        .links a { color: #0078D4; text-decoration: none; font-size: 0.9rem; }
        .links a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="card">
        <h1>NimBus</h1>
        <p class="message">@message</p>
        <div class="links">
            <a href="/account/login">Back to sign in</a>
        </div>
    </div>
</body>
</html>
