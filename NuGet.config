<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Hermetic restores: everything NimBus needs lives on nuget.org. Clearing
       inherited sources keeps machine-level feeds (e.g. private ADO feeds that
       require auth) from breaking builds or `dnx Akaule.NimBus.CommandLine`. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
