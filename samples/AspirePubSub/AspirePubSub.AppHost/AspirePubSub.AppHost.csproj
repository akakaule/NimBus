<Project Sdk="Aspire.AppHost.Sdk/13.4.3">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsAspireHost>true</IsAspireHost>
    <UserSecretsId>aspire-pubsub-sample</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.AppHost" Version="13.4.3" />
    <!-- Force the patched MessagePack over Aspire's vulnerable transitive 2.5.192
         (CVE-2026-48109 et al., patched in 2.5.301) so the audited Release build passes. -->
    <PackageReference Include="MessagePack" Version="2.5.302" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AspirePubSub.Provisioner\AspirePubSub.Provisioner.csproj" />
    <ProjectReference Include="..\AspirePubSub.ResolverWorker\AspirePubSub.ResolverWorker.csproj" />
    <ProjectReference Include="..\AspirePubSub.Publisher\AspirePubSub.Publisher.csproj" />
    <ProjectReference Include="..\AspirePubSub.Subscriber\AspirePubSub.Subscriber.csproj" />
    <ProjectReference Include="..\..\..\src\NimBus.WebApp\NimBus.WebApp.csproj" />
  </ItemGroup>

</Project>
